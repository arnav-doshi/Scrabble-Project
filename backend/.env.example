# Example environment variables for local development
# Copy this file to `.env` and fill in your Supabase project values.

# Supabase project URL (e.g. https://xxxxx.supabase.co)
SUPABASE_URL=

# Supabase service role or server key (keep secret, only on backend)
SUPABASE_KEY=

# Optional: public anon key for frontend usage (only safe for non-privileged ops)
# If you plan to initialize Supabase client in the browser, put the anon key in
# your frontend config or better, expose it through your build system.
SUPABASE_ANON_KEY=

# Server port
PORT=3000

# Node environment
NODE_ENV=development
